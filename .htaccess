<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Prevent access to sensitive files and directories
    RedirectMatch 404 /\.(git|env|bak|sql)$
    RedirectMatch 404 /(composer\.(json|lock)|package(-lock)?\.json|artisan)$

    # Case 1: If the file exists in the public directory, rewrite to it directly
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
    RewriteRule ^(.*)$ public/$1 [L]

    # Case 2: Route /storage requests directly to storage/app/public (bypasses symlink requirement)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^storage/(.*)$ storage/app/public/$1 [L]

    # Case 3: If the file does NOT exist in the root, route directly to public/index.php (prevents double-rewrite)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>
